#!/usr/bin/env bash
# faah - plays a sound when a command fails (or succeeds)

FAAH_VERSION="0.1.0"
FAAH_HOME="${FAAH_HOME:-$HOME/.faah}"
FAAH_SOUND="${FAAH_SOUND:-fahhhhh}"
FAAH_SUCCESS_SOUND="${FAAH_SUCCESS_SOUND:-}"

# Parse flags
while [ $# -gt 0 ]; do
  case "$1" in
    --sound) FAAH_SOUND="$2"; shift 2 ;;
    --success-sound) FAAH_SUCCESS_SOUND="$2"; shift 2 ;;
    --version|-v) echo "faah $FAAH_VERSION"; exit 0 ;;
    --help|-h)
      cat <<EOF
faah $FAAH_VERSION — a CLI wrapper that plays a sound when your command fails

usage:
  faah [options] <command> [args...]

options:
  --sound <name|path>          sound to play on failure (default: fahhhhh)
  --success-sound <name|path>  sound to play on success (optional)
  --version, -v                show version
  --help, -h                   show this help

sounds:
  use a built-in name or a path to your own audio file.

  built-in sounds (stored in ~/.faah/):
$(for f in "$FAAH_HOME"/*.mp3; do [ -f "$f" ] && echo "    $(basename "${f%.mp3}")"; done)

  custom sound:
    faah --sound /path/to/your/sound.mp3 pytest
    export FAAH_SOUND=/path/to/your/sound.mp3

environment variables:
  FAAH_SOUND              failure sound — name or path (default: fahhhhh)
  FAAH_SUCCESS_SOUND      success sound — name or path (unset by default)
  FAAH_HOME               built-in sounds directory (default: ~/.faah)

examples:
  faah pytest
  faah gh run watch
  faah --sound cat-meow-1 npm test
  faah --sound /path/to/airhorn.mp3 cargo build
  faah --success-sound ~/sounds/yay.mp3 make deploy
EOF
      exit 0
      ;;
    *) break ;;
  esac
done

if [ $# -eq 0 ]; then
  echo "usage: faah [options] <command> [args...]"
  echo "run 'faah --help' for more information"
  exit 1
fi

# Resolve sound value to a file path.
# If it contains a / or ends in a sound extension, treat as a path.
# Otherwise, look up by name in FAAH_HOME.
resolve_sound() {
  local val="$1"
  if [[ "$val" == */* || "$val" == *.mp3 || "$val" == *.wav || "$val" == *.ogg ]]; then
    echo "$val"
  else
    echo "$FAAH_HOME/$val.mp3"
  fi
}

play_sound() {
  local file="$1"
  if [ ! -f "$file" ]; then
    echo "faah: sound not found: $file" >&2
    return 1
  fi
  if command -v afplay &>/dev/null; then
    afplay "$file" &
  elif command -v paplay &>/dev/null; then
    paplay "$file" &
  elif command -v aplay &>/dev/null; then
    aplay "$file" &
  elif command -v mpv &>/dev/null; then
    mpv --no-video "$file" &>/dev/null &
  elif command -v ffplay &>/dev/null; then
    ffplay -nodisp -autoexit "$file" &>/dev/null &
  elif command -v powershell.exe &>/dev/null; then
    powershell.exe -c "(New-Object Media.SoundPlayer '$(wslpath -w "$file")').PlaySync()" &>/dev/null &
  fi
}

"$@"
exit_code=$?

if [ $exit_code -ne 0 ]; then
  play_sound "$(resolve_sound "$FAAH_SOUND")"
elif [ -n "$FAAH_SUCCESS_SOUND" ]; then
  play_sound "$(resolve_sound "$FAAH_SUCCESS_SOUND")"
fi

exit $exit_code
